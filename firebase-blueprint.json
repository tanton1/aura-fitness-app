{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "trainer", "staff"] },
        "branchId": { "type": "string" },
        "employeeCode": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Global schedule information",
      "type": "object",
      "properties": {
        "trainers": { "type": "array" },
        "branches": { "type": "array" },
        "staff": { "type": "array" },
        "students": { "type": "array" },
        "contracts": { "type": "array" },
        "packages": { "type": "array" },
        "sessions": { "type": "array" }
      }
    },
    "HealthyDish": {
      "title": "HealthyDish",
      "description": "Healthy Vietnamese dish information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ingredients": { "type": "array" },
        "portionSize": { "type": "string" },
        "calories": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["name", "calories", "category"]
    },
    "MealPlan": {
      "title": "MealPlan",
      "description": "Weekly meal plan for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "targetCalories": { "type": "number" },
        "weekStartDate": { "type": "string" },
        "days": { "type": "array" }
      },
      "required": ["userId", "targetCalories", "weekStartDate", "days"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/schedules/global_schedule": {
      "schema": { "$ref": "Schedule" },
      "description": "Global schedule data"
    },
    "/dailyCheckins/{checkinId}": {
      "schema": {
        "title": "DailyCheckin",
        "type": "object",
        "properties": {
          "studentId": { "type": "string" },
          "date": { "type": "string" },
          "hunger": { "type": "number" },
          "energy": { "type": "number" },
          "compliance": { "type": "number" },
          "note": { "type": "string" }
        }
      },
      "description": "Daily student check-ins"
    },
    "/healthyDishes/{dishId}": {
      "schema": { "$ref": "HealthyDish" },
      "description": "Healthy Vietnamese dishes"
    },
    "/mealPlans/{planId}": {
      "schema": { "$ref": "MealPlan" },
      "description": "Weekly meal plans"
    }
  }
}
